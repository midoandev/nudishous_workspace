
create_firebase_options_prod:
	flutterfire configure \
	  --project=nudishous \
	  --out=lib/src/config/firebase_options/firebase_options_prod.dart \
	  --platforms=android,ios \
	  --android-app-id=id.midosaurus.nudishous \
	  --ios-bundle-id=id.midosaurus.nudishous

create_firebase_options_dev:
	flutterfire configure \
      --project=nudishous-dev \
      --out=lib/src/config/firebase_options/firebase_options_dev.dart \
      --platforms=android,ios \
      --android-app-id=id.midosaurus.nudishous.dev \
      --ios-bundle-id=id.midosaurus.nudishous.dev